APP_ENV=dev

# OpenRouter LLM API
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# AgentMail
AGENTMAIL_API_KEY=
AGENTMAIL_INBOX_ID=
EMAIL_FROM=your-email@example.com

# NewsData.io
NEWSDATA_API_KEY=

# Local paths
DATABASE_PATH=data/andyjuan.db
LOG_FILE=data/logs/andyjuan.jsonl

# Model overrides
LLM_SCORING_MODEL=anthropic/claude-haiku-4.5
LLM_SYNTHESIS_MODEL=anthropic/claude-sonnet-4-6
LLM_FACT_CHECK_MODEL=anthropic/claude-haiku-4.5
LLM_FALLBACK_MODEL=anthropic/claude-haiku-4.5
