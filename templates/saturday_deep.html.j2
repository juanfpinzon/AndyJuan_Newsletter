{% extends "daily_email.html.j2" %}

{% block synthesis_copy %}
  {% set paragraphs = deep_synthesis_paragraphs if deep_synthesis_paragraphs is defined and deep_synthesis_paragraphs else synthesis_paragraphs %}
  {% for paragraph in paragraphs %}
  <p>{{ paragraph }}</p>
  {% endfor %}
{% endblock %}

{% block week_ahead %}
  <section class="panel section" data-section="week-ahead">
    <div class="eyebrow">Week Ahead</div>
    {% if week_ahead_items %}
    <table class="table" role="presentation" cellspacing="0" cellpadding="0" style="margin-top:12px;">
      <thead>
        <tr>
          <th>Date</th>
          <th>Event</th>
          <th>Kind</th>
        </tr>
      </thead>
      <tbody>
        {% for item in week_ahead_items %}
        <tr>
          <td style="color:#ffffff;font-weight:700;">{{ item.date_label }}</td>
          <td>{{ item.label }}</td>
          <td class="muted">{{ item.kind }}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
    {% else %}
    <p class="footer-note" style="margin:12px 0 0;">
      No week-ahead items were supplied for this Saturday run.
    </p>
    {% endif %}
  </section>
{% endblock %}
